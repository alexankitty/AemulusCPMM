<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AemulusModManager.Avalonia.Views.InputBox"
        Title="New Input"
        Width="350" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#202020"
        SizeToContent="Height" xmlns:vm="using:AemulusModManager.Avalonia.ViewModels" xmlns:conv="clr-namespace:AemulusModManager.Avalonia.Converters"
        x:DataType="vm:DialogWindowViewModel"
        >
    <Window.Resources>
        <conv:GameColorConverter x:Key="GameColorConverter" />
        <conv:AccentForegroundConverter x:Key="AccentForegroundConverter" />
        <conv:AccentDarkenConverter x:Key="AccentDarkenConverter" />
    </Window.Resources>
    <Window.Styles>
                <Style Selector="Button">
                        <Setter Property="Background" Value="#303030" />
                        <Setter Property="Foreground" Value="#f2f2f2" />
                </Style>
                <Style Selector="TextBox">
                        <Setter Property="Background" Value="#202020" />
                        <Setter Property="BorderBrush" Value="#424242" />
                        <Setter Property="Foreground" Value="#f2f2f2" />
                </Style>
                <Style Selector="TextBox:focus /template/ Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
                <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                        <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
                <Style Selector="CheckBox:checked /template/ Path#CheckGlyph">
                        <Setter Property="Fill" Value="{DynamicResource AccentButtonForeground}" />
                </Style>
                <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
                        <Setter Property="Opacity" Value="0.7" />
                </Style>
                <Style Selector="CheckBox:pressed /template/ Border#NormalRectangle">
                        <Setter Property="Opacity" Value="0.8" />
                </Style>
        </Window.Styles>
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Text="Input Text" Foreground="#f2f2f2" Margin="0,0,0,10"/>
        <TextBox x:Name="InputTextBox" Background="#303030" Foreground="#f2f2f2"
                 BorderBrush="#404040" Watermark="Type here..." Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="ConfirmButton" Content="Confirm" Click="Confirm_Click"
                    Classes="accent"/>
            <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
