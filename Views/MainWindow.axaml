<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AemulusModManager.Avalonia.ViewModels"
        xmlns:conv="using:AemulusModManager.Avalonia.Converters"
        xmlns:asyncImageLoader="using:AsyncImageLoader"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="AemulusModManager.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="1280" Height="720"
        MinWidth="1280" MinHeight="720"
        Background="{DynamicResource AppBg}"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <ResourceDictionary>
            <conv:GameIconConverter x:Key="GameIconConverter" />
            <conv:GameColorConverter x:Key="GameColorConverter" />
            <conv:UrlConverter x:Key="UrlConverter" />

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBg" Color="#151515"/>
                    <SolidColorBrush x:Key="AppSurface" Color="#202020"/>
                    <SolidColorBrush x:Key="AppControl" Color="#303030"/>
                    <SolidColorBrush x:Key="AppBorder" Color="#404040"/>
                    <SolidColorBrush x:Key="AppFg" Color="#f2f2f2"/>
                    <SolidColorBrush x:Key="AppMuted" Color="#9c9c9c"/>
                    <SolidColorBrush x:Key="AppConsoleBg" Color="#101010"/>
                    <SolidColorBrush x:Key="AppFeedBg" Color="#1a1a1a"/>
                    <SolidColorBrush x:Key="AppFeedCard" Color="#252525"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBg" Color="#f0f0f0"/>
                    <SolidColorBrush x:Key="AppSurface" Color="#ffffff"/>
                    <SolidColorBrush x:Key="AppControl" Color="#e0e0e0"/>
                    <SolidColorBrush x:Key="AppBorder" Color="#cccccc"/>
                    <SolidColorBrush x:Key="AppFg" Color="#1a1a1a"/>
                    <SolidColorBrush x:Key="AppMuted" Color="#666666"/>
                    <SolidColorBrush x:Key="AppConsoleBg" Color="#f8f8f8"/>
                    <SolidColorBrush x:Key="AppFeedBg" Color="#f5f5f5"/>
                    <SolidColorBrush x:Key="AppFeedCard" Color="#ffffff"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <!-- Theme-aware button style -->
        <Style Selector="Button.darkBtn">
            <Setter Property="Background" Value="{DynamicResource AppControl}" />
            <Setter Property="Foreground" Value="{DynamicResource AppFg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="Button.darkBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#9a0000" />
        </Style>
        <Style Selector="Button.darkBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#700000" />
        </Style>
        <Style Selector="Button.iconBtn">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#30ffffff" />
        </Style>
        <Style Selector="Button.iconBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#50ffffff" />
        </Style>

        <!-- DataGrid styling -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{DynamicResource AppSurface}" />
            <Setter Property="RowBackground" Value="{DynamicResource AppSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppControl}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AppControl}" />
            <Setter Property="Foreground" Value="{DynamicResource AppFg}" />
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}" />
        </Style>
    </Window.Styles>

    <TabControl Background="{DynamicResource AppBg}" SelectionChanged="TabControl_SelectionChanged">
        <!-- Tab 1: Manage Packages -->
        <TabItem Header="Manage Packages" Foreground="{DynamicResource AppFg}">
            <DockPanel>
            <!-- Bottom Status Bar -->
            <Grid DockPanel.Dock="Bottom" Margin="10,0,10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand" VerticalAlignment="Center">
                    <StackPanel.Styles>
                        <Style Selector="StackPanel:pointerover > TextBlock">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Style>
                    </StackPanel.Styles>
                    <i:Icon Value="fa-solid fa-question" FontSize="13" Foreground="{DynamicResource AppMuted}" Margin="0,0,5,0"/>
                    <TextBlock Text="Setup Guide" Foreground="{DynamicResource AppMuted}" FontSize="13"
                               PointerPressed="SetupGuide_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel.Styles>
                        <Style Selector="StackPanel:pointerover > TextBlock">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Style>
                    </StackPanel.Styles>
                    <i:Icon Value="fa-solid fa-mug-hot" FontSize="13" Foreground="{DynamicResource AppMuted}" Margin="0,0,5,0"/>
                    <TextBlock Text="Support Me!" Foreground="{DynamicResource AppMuted}" FontSize="13"
                               PointerPressed="SupportMe_Click"/>
                </StackPanel>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="400" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Package List -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="150" />
                    </Grid.RowDefinitions>

                    <!-- Top Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Game Selector -->
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding GameList}"
                                  SelectedItem="{Binding SelectedGame}"
                                  IsEnabled="{Binding IsUiEnabled}"
                                  Margin="0,0,3,0"
                                  MinWidth="230"
                                  Background="{DynamicResource AppControl}"
                                  Foreground="{DynamicResource AppFg}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Width="24" Height="24" Margin="2,0,8,0"
                                               Source="{Binding Converter={StaticResource GameIconConverter}}" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Loadout Selector -->
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding LoadoutItems}"
                                  SelectedItem="{Binding SelectedLoadout}"
                                  IsEnabled="{Binding IsUiEnabled}"
                                  Margin="0,0,3,0"
                                  MinWidth="120"
                                  Background="{DynamicResource AppControl}"
                                  Foreground="{DynamicResource AppFg}" />

                        <!-- Config -->
                        <Button Grid.Column="2" Classes="darkBtn iconBtn"
                                Click="ConfigButton_Click"
                                IsEnabled="{Binding IsUiEnabled}"
                                ToolTip.Tip="Config"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-gear" FontSize="18" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Refresh -->
                        <Button Grid.Column="3" Classes="darkBtn iconBtn"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding IsUiEnabled}"
                                ToolTip.Tip="Refresh"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-arrows-rotate" FontSize="18" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Build -->
                        <Button Grid.Column="4" Classes="darkBtn iconBtn"
                                Command="{Binding BuildCommand}"
                                IsEnabled="{Binding IsBuildEnabled}"
                                ToolTip.Tip="Build"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-hammer" FontSize="16" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Launch -->
                        <Button Grid.Column="5" Classes="darkBtn iconBtn"
                                Command="{Binding LaunchGameCommand}"
                                IsEnabled="{Binding IsUiEnabled}"
                                ToolTip.Tip="Launch Game"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-rocket" FontSize="16" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Open Folder -->
                        <Button Grid.Column="6" Classes="darkBtn iconBtn"
                                Command="{Binding OpenModDirCommand}"
                                ToolTip.Tip="Open Mod Folder"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-folder-open" FontSize="16" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Add Package -->
                        <Button Grid.Column="7" Classes="darkBtn iconBtn"
                                Click="AddPackage_Click"
                                IsEnabled="{Binding IsUiEnabled}"
                                ToolTip.Tip="Add Package"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-plus" FontSize="18" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Create New Package -->
                        <Button Grid.Column="8" Classes="darkBtn iconBtn"
                                Click="CreatePackage_Click"
                                IsEnabled="{Binding IsUiEnabled}"
                                ToolTip.Tip="Create New Package"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-file-circle-plus" FontSize="18" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Priority Swap -->
                        <Button Grid.Column="9" Classes="darkBtn iconBtn"
                                Command="{Binding SwapPriorityCommand}"
                                ToolTip.Tip="{Binding PriorityLabel}"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-sort" FontSize="18" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Dark Mode Toggle -->
                        <Button Grid.Column="10" Classes="darkBtn iconBtn"
                                Command="{Binding ToggleDarkModeCommand}"
                                ToolTip.Tip="Toggle Dark/Light Mode"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <i:Icon Value="fa-solid fa-circle-half-stroke" FontSize="18" Foreground="{Binding GameAccentColor}"/>
                        </Button>

                        <!-- Package Stats -->
                        <TextBlock Grid.Column="11"
                                   Text="{Binding PackageStats}"
                                   Foreground="{DynamicResource AppMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="5,0,5,0"/>

                        <!-- Search Box -->
                        <TextBox Grid.Column="12"
                                 Watermark="Search..."
                                 Text="{Binding SearchText}"
                                 MinWidth="150"
                                 Background="{DynamicResource AppControl}"
                                 Foreground="{DynamicResource AppFg}"
                                 BorderBrush="{DynamicResource AppBorder}" />
                    </Grid>

                    <!-- Package DataGrid with Priority indicator -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                              Name="PackageGrid"
                              ItemsSource="{Binding DisplayedPackages}"
                              SelectedItem="{Binding SelectedPackage}"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              SelectionMode="Single"
                              IsReadOnly="False"
                              KeyDown="PackageGrid_KeyDown">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open Package Folder" Command="{Binding OpenPackageFolderCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-folder-open" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Edit Metadata" Command="{Binding EditPackageMetadataCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-pen" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Zip Package" Command="{Binding ZipPackageCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-file-zipper" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Convert to CPK Structure" Command="{Binding ConvertCPKCommand}"
                                          IsVisible="{Binding SelectedGame, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-right-left" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Check For Updates" Command="{Binding UpdateSelectedPackageCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-download" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Hide Package" Command="{Binding HidePackageCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-eye-slash" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Unhide Package" Command="{Binding UnhidePackageCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-eye" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Delete Package" Command="{Binding DeletePackageCommand}">
                                    <MenuItem.Icon><i:Icon Value="fa-solid fa-trash" FontSize="14" Foreground="#ff4444"/></MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Enabled" Width="90"
                                                    CanUserResize="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding enabled, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  Checked="OnPackageChecked"
                                                  Unchecked="OnPackageUnchecked"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding name}" Width="*"
                                                CanUserResize="True"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Author"
                                                Binding="{Binding author}" Width="120"
                                                CanUserResize="True"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Version"
                                                Binding="{Binding version}" Width="80"
                                                CanUserResize="True"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Link"
                                                Binding="{Binding link, Converter={StaticResource UrlConverter}}" Width="120"
                                                CanUserResize="True"
                                                IsReadOnly="True" Foreground="#0bb4c8"/>
                        </DataGrid.Columns>
                    </DataGrid>

                        <!-- Empty state hint (shown when no packages) -->
                        <Border Grid.Column="0" Name="EmptyHint"
                                IsVisible="{Binding !DisplayedPackages.Count}"
                                IsHitTestVisible="False" ZIndex="5"
                                Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Opacity="0.5">
                                <i:Icon Value="fa-solid fa-box-open" FontSize="40" Foreground="#9c9c9c"
                                        HorizontalAlignment="Center"/>
                                <TextBlock Text="No packages installed" Foreground="#9c9c9c"
                                           FontSize="18" HorizontalAlignment="Center"/>
                                <TextBlock Text="Click the + button or drag archives here to add packages"
                                           Foreground="#707070" FontSize="13" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Active drag overlay -->
                        <Border Grid.Column="0" Name="DropOverlay" IsVisible="False" IsHitTestVisible="False"
                                ZIndex="10" Background="#CC1a1a1a" CornerRadius="5"
                                BorderBrush="{Binding GameAccentColor}" BorderThickness="2">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <i:Icon Value="fa-solid fa-file-import" FontSize="48" Foreground="#cccccc"
                                        HorizontalAlignment="Center"/>
                                <TextBlock Text="Drop Existing Package to Install" Foreground="#f2f2f2"
                                           FontSize="24" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Priority Indicator Bar -->
                        <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                                Margin="3,0,0,0" Background="{DynamicResource AppSurface}" Width="35">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <i:Icon Grid.Row="0" Value="fa-solid fa-sort-up" FontSize="14"
                                        Foreground="{DynamicResource AppMuted}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Text="PACKAGE PRIORITY"
                                           Foreground="{DynamicResource AppMuted}" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <i:Icon Grid.Row="2" Value="fa-solid fa-sort-down" FontSize="14"
                                        Foreground="{DynamicResource AppMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Row="2" Background="{DynamicResource AppControl}" />

                    <!-- Console Output -->
                    <Grid Grid.Row="3">
                        <TextBox Text="{Binding ConsoleOutput}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="{DynamicResource AppConsoleBg}"
                                 Foreground="#90EE90"
                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                 FontSize="12"
                                 CaretIndex="{Binding ConsoleOutput.Length, Mode=OneWay}" />
                        <Button Content="Clear Logs" Classes="darkBtn"
                                Command="{Binding ClearConsoleCommand}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,4,4,0" Padding="6,2"
                                FontSize="10" Opacity="0.8"/>
                    </Grid>
                </Grid>

                <GridSplitter Grid.Column="1" Background="{DynamicResource AppControl}" />

                <!-- Right Panel: Details / Preview -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Preview Image -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource AppSurface}"
                            CornerRadius="5"
                            Margin="5">
                        <Image Source="{Binding PreviewImage}"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="4,5,4,2" />
                    </Border>

                    <GridSplitter Grid.Row="1" Background="{DynamicResource AppControl}" />

                    <!-- Description -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource AppSurface}"
                            CornerRadius="5"
                            Margin="5"
                            Padding="10">
                        <ScrollViewer>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="{DynamicResource AppFg}"
                                       TextWrapping="Wrap"
                                       FontSize="14" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
            </DockPanel>
        </TabItem>

        <!-- Tab 2: Download Packages -->
        <TabItem Header="Download Packages" Foreground="{DynamicResource AppFg}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Top Filter Bar -->
                <WrapPanel Grid.Row="0" Margin="5" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBlock Text="Game:" Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="GameFilterBox" Width="180" SelectionChanged="GameFilterSelectionChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBlock Text="Type:" Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="TypeBox" Width="100" SelectionChanged="TypeFilterSelectionChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBlock Text="Category:" Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CatBox" Width="150" SelectionChanged="MainFilterSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBlock Text="Sub:" Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SubCatBox" Width="120" SelectionChanged="SubFilterSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBlock Text="Sort:" Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FilterBox" Width="110" SelectionChanged="FilterSelectionChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBox x:Name="SearchBar" Width="150" Watermark="Search..." KeyDown="SearchBar_KeyDown"/>
                        <Button Content="Search" Click="SearchButton_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                        <TextBlock Text="Per Page:" Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PerPageBox" Width="60" SelectionChanged="PerPageSelectionChanged"/>
                    </StackPanel>
                </WrapPanel>

                <!-- Main Content: Feed List -->
                <Grid Grid.Row="1">
                    <ListBox x:Name="FeedBox" Background="{DynamicResource AppBg}" Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource AppFeedCard}" CornerRadius="5" Padding="8" Margin="2">
                                    <Grid ColumnDefinitions="80,*,Auto">
                                        <!-- Thumbnail -->
                                        <Image Grid.Column="0" Width="70" Height="70" Stretch="UniformToFill"
                                               asyncImageLoader:ImageLoader.Source="{Binding Image}" Margin="0,0,8,0"/>
                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"
                                                       Foreground="{DynamicResource AppFg}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Foreground="#909090" FontSize="11">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="by {0} | {1}">
                                                        <Binding Path="Owner.Name"/>
                                                        <Binding Path="CategoryName"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Downloads, StringFormat='{}{0} DLs'}" Foreground="#707070" FontSize="10"/>
                                                <TextBlock Text="{Binding Likes, StringFormat='{}{0} Likes'}" Foreground="#707070" FontSize="10"/>
                                                <TextBlock Text="{Binding Views, StringFormat='{}{0} Views'}" Foreground="#707070" FontSize="10"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="#606060" FontSize="10"
                                                       MaxLines="2" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="5" VerticalAlignment="Center" Margin="5,0,0,0">
                                            <Button Content="Download" Click="Download_Click" Tag="{Binding}" Padding="8,4"/>
                                            <Button Content="More Info" Click="MoreInfo_Click" Tag="{Binding}" Padding="8,4"/>
                                            <Button Content="Homepage" Click="Homepage_Click" Tag="{Binding}" Padding="8,4"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Loading indicator -->
                    <Border x:Name="LoadingPanel" Background="#80000000" IsVisible="False">
                        <TextBlock Text="Loading..." Foreground="White" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Error panel -->
                    <Border x:Name="ErrorPanel" Background="#80000000" IsVisible="False">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <TextBlock x:Name="BrowserMessage" Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
                            <Button x:Name="BrowserRefreshButton" Content="Refresh" Click="BrowserRefresh_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom Pagination -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="5">
                    <Button Content="&lt;" Click="DecrementPage"/>
                    <ComboBox x:Name="PageBox" Width="60" SelectionChanged="PageBox_SelectionChanged"/>
                    <Button Content="&gt;" Click="IncrementPage"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
