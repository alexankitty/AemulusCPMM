<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AemulusModManager.Avalonia.Views.PackageFolderBox"
        Title="Aemulus Package Manager"
        CanResize="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#121212">
        <Window.Styles>
                <Style Selector="Button">
                        <Setter Property="Background" Value="#303030" />
                        <Setter Property="Foreground" Value="#f2f2f2" />
                </Style>
                <Style Selector="TextBox">
                        <Setter Property="Background" Value="#202020" />
                        <Setter Property="BorderBrush" Value="#424242" />
                        <Setter Property="Foreground" Value="#f2f2f2" />
                </Style>
                <Style Selector="TextBox:focus /template/ Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
                <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                        <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
                <Style Selector="CheckBox:checked /template/ Path#CheckGlyph">
                        <Setter Property="Fill" Value="{DynamicResource AccentButtonForeground}" />
                </Style>
                <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
                        <Setter Property="Opacity" Value="0.7" />
                </Style>
                <Style Selector="CheckBox:pressed /template/ Border#NormalRectangle">
                        <Setter Property="Opacity" Value="0.8" />
                </Style>
        </Window.Styles>
    <Grid RowDefinitions="Auto,*,Auto" MinWidth="300">
        <TextBlock Padding="20" Foreground="White" VerticalAlignment="Top"
                   TextWrapping="WrapWithOverflow" FontSize="15"
                   Text="Multiple Package.xml's found. Please select the correct Aemulus package folder."
                   Grid.Row="0"/>
        <DataGrid x:Name="FileGrid" Grid.Row="1" HorizontalAlignment="Center"
                  VerticalAlignment="Center" AutoGenerateColumns="False"
                  Margin="25,5,25,10" Background="#121212" Foreground="White"
                  IsReadOnly="True" GridLinesVisibility="None">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Folder Directory" Binding="{Binding}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,0,0,10" Spacing="20">
            <Button x:Name="SelectButton" Content="Select" 
                    Classes="accent" Click="SelectButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" 
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
