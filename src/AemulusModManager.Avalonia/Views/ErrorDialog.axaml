<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AemulusModManager.Avalonia.Views.ErrorDialog"
        Title="Error"
        Width="400" Height="180">
    <StackPanel Margin="16">
        <TextBlock x:Name="ErrorText" TextWrapping="Wrap" FontSize="16"/>
        <Button Content="OK" HorizontalAlignment="Right" Width="80" Margin="0,16,0,0" Click="OnOkClick"/>
    </StackPanel>
</Window>
