<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AemulusModManager.Avalonia.Views.UpdateFileBox"
        Title="Aemulus Package Manager"
        CanResize="False" MinWidth="600" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#202020">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" x:Name="TitleBox" FontSize="20" FontWeight="Bold"
                   Foreground="#f2f2f2" HorizontalAlignment="Center" Margin="10" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="1" Text="Multiple downloads were found, choose one:"
                   Foreground="#a2a2a2" HorizontalAlignment="Center" FontSize="14" Margin="5"/>
        <ListBox Grid.Row="2" x:Name="FileList" MaxHeight="500" Background="#202020"
                 Margin="10" SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Button Click="SelectButton_Click" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Background="#494949" Margin="2">
                        <Grid RowDefinitions="Auto,Auto,Auto" Margin="3">
                            <TextBlock Grid.Row="0" FontSize="18" FontWeight="Bold"
                                       Foreground="#f2f2f2" Text="{Binding FileName}"/>
                            <TextBlock Grid.Row="1" FontSize="13" Foreground="#a2a2a2">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} · Uploaded {1} · {2} downloads">
                                        <Binding Path="ConvertedFileSize"/>
                                        <Binding Path="TimeSinceUpload"/>
                                        <Binding Path="DownloadString"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Grid.Row="2" FontSize="13" Foreground="#a2a2a2"
                                       Text="{Binding Description}"/>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Grid.Row="3" x:Name="CancelButton" Content="Cancel" Background="#494949"
                Foreground="#f2f2f2" FontSize="14" Height="30" Width="100"
                HorizontalAlignment="Center" Margin="10" Click="CancelButton_Click"/>
    </Grid>
</Window>
